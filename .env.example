# Copy this file to .env and fill in ALL values before running docker compose.
# Never commit .env to version control.
# All passwords are REQUIRED — the stack will fail to start if any are left blank.

POSTGRES_DB=sengrid
POSTGRES_USER=sengrid
POSTGRES_PASSWORD=REPLACE_BEFORE_USE

REDIS_PASSWORD=REPLACE_BEFORE_USE

RABBITMQ_DEFAULT_USER=REPLACE_BEFORE_USE
RABBITMQ_DEFAULT_PASS=REPLACE_BEFORE_USE

MINIO_ROOT_USER=REPLACE_BEFORE_USE
MINIO_ROOT_PASSWORD=REPLACE_BEFORE_USE

GRAFANA_ADMIN_PASSWORD=REPLACE_BEFORE_USE

# Optional: relay profile settings (only needed if running with --profile relay)
RELAY_ALLOWED_SENDER_DOMAINS=yourdomain.com
RELAY_HOSTNAME=mail.yourdomain.com
RELAY_HOST=
